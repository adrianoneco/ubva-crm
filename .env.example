# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=webglass_bot

# Feature Flags
ENABLE_CRM=true
ENABLE_DASHBOARD=true
ENABLE_KANBAN=true
ENABLE_CONTACTS=true

# Server Configuration
PORT=5006

# Global API Key
GLOBAL_API_KEY=your_api_key_here

# Webhook configuration for Kanban -> n8n
KB_WEBHOOK_URL=https://n8n.ubva.com.br/webhook/webglass-kanban
KB_WEBHOOK_SECRET=your_webhook_secret

# Z-API WhatsApp Integration
ZAPI_INSTANCE_ID=your_instance_id
ZAPI_INSTANCE_TOKEN=your_instance_token
ZAPI_SECURITY_TOKEN=your_security_token

# OTP Configuration
# OTP code expiry time in seconds (default: 300 = 5 minutes)
OTP_EXPIRES_IN=300

# SMTP Configuration (optional - enables email verification in password recovery)
# Leave blank to disable email verification
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_password
SMTP_FROM=noreply@example.com
